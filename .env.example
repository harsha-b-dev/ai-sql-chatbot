GROQ_API_KEY=your_groq_api_key_here

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=ecommerce_ai

# Set this only for local MySQL servers that do not support SSL.
# Leave it unset for cloud MySQL providers such as Aiven.
MYSQL_SSL_DISABLED=true
